# WhatsX Backend Environment

PORT=4000
CORS_ORIGIN=http://localhost:5173
ALLOW_OPEN_REGISTRATION=true

# Prefer providing the full service account JSON as base64 (recommended)
FIREBASE_SERVICE_ACCOUNT_B64=

# Or provide discrete credentials instead (escape newlines in PRIVATE_KEY as \n)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=

# WhatsApp Cloud API (optional; if omitted, sends are simulated)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Cron schedule for processing scheduled messages (default: every minute)
CRON_SCHEDULE=* * * * *
