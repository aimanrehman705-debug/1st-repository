# Backend environment variables for WhatsX
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Firebase Admin - choose one method below
# 1) Provide fields directly (escape newlines in PRIVATE KEY with \\n)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENTS\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com

# 2) Alternatively, provide a base64 JSON service account
# FIREBASE_SERVICE_ACCOUNT_B64=eyJ0eXAiOiJKV1QiLCJhbGci...

# WhatsApp Cloud API (optional for local dev; stubbed if missing)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Scheduler cron (default runs every minute)
CRON_SCHEDULE=* * * * *

# Allow open registration via /auth/register without prior admin
ALLOW_OPEN_REGISTRATION=true
