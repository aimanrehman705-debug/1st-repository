# Backend Environment Variables for WhatsX
PORT=5000
CORS_ORIGIN=http://localhost:5173

# Firebase Admin SDK service account (use multiline private key with proper escaping)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_LINES\n-----END PRIVATE KEY-----\n"

# WhatsApp Cloud API
WHATSAPP_TOKEN=your_whatsapp_graph_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Admin bootstrap (comma separated emails that should be admins)
ADMIN_EMAILS=admin@example.com
