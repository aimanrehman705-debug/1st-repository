rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.token.role == 'admin' || request.auth.uid == uid);
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
    match /templates/{id} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
    match /messages/{id} {
      allow read: if request.auth != null && (request.auth.token.role == 'admin' || resource.data.userId == request.auth.uid);
      allow write: if request.auth != null; // Prefer writes via backend
    }
  }
}
